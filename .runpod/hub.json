{
  "title": "Wan Pipeline",
  "description": "Phase 1 serverless scaffold for wan-pipeline-master",
  "type": "serverless",
  "category": "video",
  "config": {
    "runsOn": "GPU",
    "containerDiskInGb": 150,
    "gpuCount": 1,
    "allowedCudaVersions": [
      "12.8"
    ],
    "env": [
      {
        "key": "AWS_REGION",
        "value": "us-east-2"
      }
    ]
  }
}
